#Score miRNAs and sort by predicted miRNA role

```{r miRNAscore}
#We start by taking the integrated score table and splitting it up into two tables
# Function to create the tibble with the real, actual, non-permuted results
# Table contains the cumulative score for all genes of each type targeted by that mir.
compute_cumscore <- function(mirtargets, targetscorerole) {
mirtargets %>%
inner_join(targetscorerole, by="target") %>%
group_by(mirna, role) %>%
mutate(pcumscore=sum(pscore.sum),ntargets=length(target),targetlist = as.character(list(target))) %>%
ungroup() %>%
complete(mirna, role, fill=list(cumscore=0)) %>%
distinct(mirna,role,pcumscore,ntargets,targetlist)
}

if(ago1 == TRUE){
#The first table (mt) is just mirs and their targets.
integrated <- genescores.ago1

mt <- integrated %>%
distinct(mirna, target)
#The second table (tsr) is the score and role for each gene.
tsr <- integrated %>%
distinct(target, pscore.sum, role)

# Run the function to generate the actual cumulative scores for each mir/role combination
cumscores <- compute_cumscore(mirtargets=mt, targetscorerole=tsr)
cumscores$pcumscore[is.na(cumscores$pcumscore)] <- 0
cumscores$ntargets[is.na(cumscores$ntargets)] <- 0


cumscorestsg.ago1 <- cumscores %>%
  filter(role == "ONC") %>%
  arrange(desc(pcumscore))

cumscoresonc.ago1 <- cumscores %>%
  filter(role == "TSG") %>%
  arrange(desc(pcumscore))

write_xlsx(list(TumorSuppressor = cumscorestsg.ago1, Oncogene = cumscoresonc.ago1),paste(outputdir,"/ago1-mirna-scores.xlsx",sep = ""))
}

